# Override catpuccin's window name
# see https://github.com/catppuccin/tmux/issues/53
set -ogq @catppuccin_window_text " #W"
set -ogq @catppuccin_window_current_text " #W"

# Set terminal colors
# set -g default-terminal 'xterm-ghostty'
set -as terminal-features ',xterm-ghostty*:RGB'
set -g default-terminal "tmux-256color"

# Turn on extended keys
set -s extended-keys on
set -as terminal-features ',xterm-ghostty*:extkeys'

# Configure the catppuccin plugin
set -g @catppuccin_flavor "mocha"
set -g @catppuccin_window_status_style "rounded"

# Load catppuccin
run '~/.tmux/plugins/catppuccin/tmux/catppuccin.tmux'

# Make the status line pretty and add some modules
set -g status-right-length 100
set -g status-left-length 100
set -g status-left ""
set -g status-right "#{E:@catppuccin_status_application}"
set -ag status-right "#{E:@catppuccin_status_session}"
set -agF status-right "#{@catppuccin_status_gitmux}"

# remap prefix from 'C-b' to 'C-Space'
unbind C-b
set-option -g prefix C-Space
bind-key C-Space send-prefix

# split panes using | and -
bind \\ split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

# switch panes
bind -n C-M-h select-pane -L
bind -n C-M-l select-pane -R
bind -n C-M-k select-pane -U
bind -n C-M-j select-pane -D

# switch windows
bind -n M-[ previous-window
bind -n M-] next-window

# resize using Option + Arrow keys (no prefix needed)
bind -n M-S-Left resize-pane -L 1
bind -n M-S-Right resize-pane -R 1
bind -n M-S-Up resize-pane -U 1
bind -n M-S-Down resize-pane -D 1

# Enable mouse control (clickable windows, panes, resizable panes)
set -g mouse on

# Make scrolling smoother
bind -T copy-mode-vi WheelUpPane select-pane \; send-keys -X -N 1 scroll-up
bind -T copy-mode-vi WheelDownPane select-pane \; send-keys -X -N 1 scroll-down

# shortcut to clear scroll history
bind k send-keys "clear" Enter \; run-shell "sleep 1" \; clear-history

# panes
set -g pane-border-style fg=#828bb8
set -g pane-active-border-style fg=#c099ff
set -g pane-border-lines heavy

# vim keybindings
set-window-option -g mode-keys vi
bind-key -T copy-mode-vi v send -X begin-selection
bind-key -T copy-mode-vi V send -X select-line
set -s copy-command 'pbcopy'
bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel 'pbcopy'

# plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

# continually save tmux state
run-shell ~/clone/path/continuum.tmux
set -g @resurrect-capture-pane-contents 'on'
set -g @continuum-restore 'on'
set -g @continuum-save-interval '5'

# Initialize tmux plugin manager (keep this line at the very bottom of tmux.conf)
run '~/.tmux/plugins/tpm/tpm'
